# ===========================================
# mveduboard 환경 변수 (예시)
# 이 파일을 복사해 .env.local 로 저장한 뒤 값을 채우세요.
# .env.local 은 git에 커밋되지 않습니다.
# ===========================================

# --- 필수: Supabase ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- 선택: 배포 도메인 (비밀번호 재설정 리다이렉트 등, 없으면 현재 origin 사용) ---
# VITE_APP_URL=https://mveduboard.vercel.app

# --- 선택: OpenAI (문장 다듬기, 빙고 등 AI 기능 사용 시) ---
# VITE_OPENAI_API_KEY=sk-...

# --- 선택: 나이스(NEIS) 급식 API (학교알리미 연동, 급식표 탭 '오늘의 급식' 표시) ---
# https://open.neis.go.kr/portal/guide/actKeyPage.do 에서 인증키 발급
# VITE_NEIS_API_KEY=your-neis-api-key

# --- 선택: OMR / 설문 / 베타 (기본값 있음, 필요 시만 설정) ---
# VITE_OMR_MAX_QUESTIONS=200
# VITE_OMR_MIN_QUESTIONS=1
# VITE_SURVEY_ATTACHMENT_MAX_MB=5
# VITE_SURVEY_ATTACHMENT_MIME=image/*
# VITE_BETA_EVENTS_ENABLED=false

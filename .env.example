# ===========================================
# 환경 변수 예시 — 이 파일을 복사해 .env.local 로 저장한 뒤 값만 채우세요.
# .env.local 은 Git 에 커밋하지 마세요.
# ===========================================

# --- Supabase (필수) ---
# Supabase 대시보드 > Project Settings > API 에서 확인
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# --- OpenAI (선택, AI 기능 사용 시) ---
# https://platform.openai.com/api-keys 에서 발급
# gpt-4o-mini 사용: 문장 다듬기, 빙고/단어찾기 AI, 만화 키워드 등
VITE_OPENAI_API_KEY=sk-... 

# --- 선택 사항 (기본값 있음) ---
# OMR 문항 수 제한 (기본 1~200)
# VITE_OMR_MAX_QUESTIONS=200
# VITE_OMR_MIN_QUESTIONS=1

# 설문 첨부파일 (기본 5MB, image/*)
# VITE_SURVEY_ATTACHMENT_MAX_MB=5
# VITE_SURVEY_ATTACHMENT_MIME=image/*

# 베타 이벤트 로깅 (기본 비활성)
# VITE_BETA_EVENTS_ENABLED=false
